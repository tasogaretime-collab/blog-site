---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="ページが見つかりません | Tasunaro">
  <div class="max-w-3xl mx-auto px-4 py-20 text-center">
    <p class="text-6xl font-bold text-karada-blue mb-4">404</p>
    <h1 class="text-2xl font-bold text-gray-900 mb-3">ページが見つかりません</h1>
    <p class="text-gray-500 mb-8">お探しのページは移動または削除された可能性があります。</p>
    <div class="flex justify-center gap-4">
      <a href="/" class="btn-primary">トップページへ</a>
      <a href="/blog" class="btn-secondary">記事一覧へ</a>
    </div>
  </div>
</BaseLayout>
