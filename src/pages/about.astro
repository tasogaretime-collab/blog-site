---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const articleCount = allPosts.length;
---

<BaseLayout
  title="プロフィール | Tasunaro ─ 感染症専門医の医療情報ブログ"
  description="感染症専門医Tasunaroのプロフィール。資格・経歴・執筆実績・ブログのコンセプトを紹介します。"
>
  <div class="max-w-3xl mx-auto px-4 py-12">

    <!-- ヘッダー -->
    <div class="text-center mb-10">
      <img src="/images/profile.jpg" alt="Tasunaro" class="w-24 h-24 rounded-full object-cover mx-auto mb-4" />
      <h1 class="text-3xl font-bold text-gray-900 mb-1">Tasunaro</h1>
      <p class="text-karada-blue font-medium mb-4">感染症専門医</p>
      <p class="text-gray-600 text-sm leading-relaxed max-w-lg mx-auto mb-6">
        医師になって10年以上、感染症の診療を続けています。<br />
        査読論文や医学書の執筆経験を活かし、最新のエビデンスに基づいた情報をお届けします。
      </p>

      <!-- 資格バッジ -->
      <div class="flex flex-wrap justify-center gap-1.5 max-w-2xl mx-auto mb-6">
        <span class="inline-flex items-center px-2.5 py-1 text-xs font-medium text-karada-blue bg-karada-blue/5 border border-karada-blue/30 rounded-full">日本感染症学会専門医</span>
        <span class="inline-flex items-center px-2.5 py-1 text-xs font-medium text-karada-blue bg-karada-blue/5 border border-karada-blue/30 rounded-full">日本内科学会認定内科医</span>
        <span class="inline-flex items-center px-2.5 py-1 text-xs font-medium text-karada-blue bg-karada-blue/5 border border-karada-blue/30 rounded-full">抗菌化学療法指導医</span>
        <span class="inline-flex items-center px-2.5 py-1 text-xs font-medium text-karada-blue bg-karada-blue/5 border border-karada-blue/30 rounded-full">日本エイズ学会認定医</span>
        <span class="inline-flex items-center px-2.5 py-1 text-xs font-medium text-karada-blue bg-karada-blue/5 border border-karada-blue/30 rounded-full">国際渡航医学会認定医</span>
        <span class="inline-flex items-center px-2.5 py-1 text-xs font-medium text-karada-blue bg-karada-blue/5 border border-karada-blue/30 rounded-full">日本渡航医学会認定医療職</span>
        <span class="inline-flex items-center px-2.5 py-1 text-xs font-medium text-karada-blue bg-karada-blue/5 border border-karada-blue/30 rounded-full">熱帯医学・衛生学ディプロマ（DTM&amp;H）</span>
      </div>

      <!-- ブログ統計 -->
      <div class="inline-flex items-center gap-4 px-5 py-2.5 bg-gray-50 rounded-full text-xs text-gray-600">
        <span><span class="font-bold text-karada-blue">{articleCount}</span>本の記事を公開</span>
        <span class="text-gray-300">|</span>
        <span>すべて<span class="font-bold">出典付き</span></span>
        <span class="text-gray-300">|</span>
        <span>定期的に<span class="font-bold">更新</span></span>
      </div>
    </div>

    <div class="prose max-w-none">

      <!-- このブログについて -->
      <h2>このブログで得られること</h2>
      <p>
        「ネットで調べたけど、結局どれが正しい情報かわからない」──そんなときに読んでもらえたらうれしいです。
      </p>
      <ul>
        <li>感染症・ワクチン・抗菌薬・渡航医学について、最新の論文やガイドラインに基づいた情報</li>
        <li>外来でよく聞かれる疑問・誤解されやすいポイントの整理</li>
        <li>自身で判断するための材料になる解説</li>
      </ul>

      <!-- 執筆・学術 -->
      <h2>執筆・学術活動</h2>
      <ul>
        <li>医学書・専門誌への分担執筆 10冊以上（抗菌薬・感染症領域）</li>
        <li>国内外の学術誌に原著論文・症例報告を発表（英文論文含む）</li>
        <li>市民向けの医療講演も行っています</li>
      </ul>

      <!-- 記事の品質管理 -->
      <h2>記事の品質管理</h2>
      <ul>
        <li>主に査読済みの論文・診療ガイドライン・公的機関の情報をもとに執筆しています</li>
        <li>記事内に出典を載せているので、元の情報もご自身で確認できます</li>
        <li>ガイドラインの改訂や新しいエビデンスが出たときは、記事を更新します</li>
        <li>感染症を専門とする現役の医師が、医学的な正確性をチェックしています</li>
      </ul>

      <!-- SNS・お問い合わせ -->
      <h2>SNS・お問い合わせ</h2>
      <p>
        <a href="https://x.com/xRLtqMcxxZ75089" target="_blank" rel="noopener noreferrer">X（旧Twitter）</a>で記事の図解や感染症の最新情報を発信しています。
        記事へのご意見やご質問は X の DM までお気軽にお寄せください。
      </p>

      <!-- 免責事項 -->
      <h2>免責事項</h2>
      <p>
        このブログは医療情報の提供・啓発が目的です。個別の診断や治療の代わりにはなりません。
        気になる症状があるときは、かかりつけ医にご相談ください。
        詳しくは<a href="/disclaimer">免責事項ページ</a>をご覧ください。
      </p>
    </div>
  </div>
</BaseLayout>
