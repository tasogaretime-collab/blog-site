---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShopCard from '../../components/ShopCard.astro';
import { getCollection } from 'astro:content';

const allItems = await getCollection('shop');
const svgIcons = allItems.filter((i) => i.data.category === 'svg-icons');
const pptxTemplates = allItems.filter((i) => i.data.category === 'pptx-template');
const guides = allItems.filter((i) => i.data.category === 'guide');
---

<BaseLayout
  title="デジタル素材ショップ | 医療系アイコン・スライドテンプレート"
  description="医療系アニメーションSVGアイコン・PPTXテンプレートなど、医療コンテンツ制作に使えるデジタル素材を販売しています。"
>
  <div class="max-w-5xl mx-auto px-4 py-10">
    <!-- Header -->
    <div class="text-center mb-12">
      <h1 class="text-3xl font-bold text-gray-900 mb-3">デジタル素材ショップ</h1>
      <p class="text-gray-500 max-w-2xl mx-auto leading-relaxed">
        医療系プレゼンテーション・SNS投稿・患者さんへの説明に使えるデジタル素材を販売しています。
        感染症専門医が実際に使用する素材から生まれた、医学的に正確なアイコン・テンプレートです。
      </p>
    </div>

    <!-- How it works -->
    <div class="bg-karada-blue-light rounded-xl p-6 mb-12">
      <h2 class="text-lg font-bold text-karada-blue-dark mb-4 text-center">購入の流れ</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-center text-sm">
        <div class="flex flex-col items-center gap-2">
          <div class="w-10 h-10 rounded-full bg-karada-blue text-white flex items-center justify-center font-bold">1</div>
          <div class="font-medium text-gray-800">商品を選ぶ</div>
          <div class="text-gray-500">無料サンプルでまず確認</div>
        </div>
        <div class="flex flex-col items-center gap-2">
          <div class="w-10 h-10 rounded-full bg-karada-blue text-white flex items-center justify-center font-bold">2</div>
          <div class="font-medium text-gray-800">Gumroadで購入</div>
          <div class="text-gray-500">クレカ・PayPal対応</div>
        </div>
        <div class="flex flex-col items-center gap-2">
          <div class="w-10 h-10 rounded-full bg-karada-blue text-white flex items-center justify-center font-bold">3</div>
          <div class="font-medium text-gray-800">即座にダウンロード</div>
          <div class="text-gray-500">SVG/PNG/PPTX形式</div>
        </div>
      </div>
    </div>

    <!-- SVG Icons section -->
    {svgIcons.length > 0 && (
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-gray-900 mb-2">医療系アニメーションアイコン</h2>
        <p class="text-gray-500 text-sm mb-6">Gemini Canvasで制作した、アニメーション付きSVGアイコン集。プレゼン・Webサイト・SNS投稿に。</p>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {svgIcons.map((item) => (
            <ShopCard
              title={item.data.title}
              description={item.data.description}
              price={item.data.price}
              gumroadUrl={item.data.gumroadUrl}
              previewImages={item.data.previewImages}
              category={item.data.category}
              featured={item.data.featured}
            />
          ))}
        </div>
      </section>
    )}

    <!-- PPTX Templates section -->
    {pptxTemplates.length > 0 && (
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-gray-900 mb-2">PPTXスライドテンプレート</h2>
        <p class="text-gray-500 text-sm mb-6">医療情報発信・学会発表・勉強会に使えるデザイン済みテンプレート。</p>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {pptxTemplates.map((item) => (
            <ShopCard
              title={item.data.title}
              description={item.data.description}
              price={item.data.price}
              gumroadUrl={item.data.gumroadUrl}
              previewImages={item.data.previewImages}
              category={item.data.category}
              featured={item.data.featured}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Guide section -->
    {guides.length > 0 && (
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-gray-900 mb-2">医療解説資料</h2>
        <p class="text-gray-500 text-sm mb-6">患者さんへの説明や院内掲示に使える、印刷対応の解説資料PDF。</p>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {guides.map((item) => (
            <ShopCard
              title={item.data.title}
              description={item.data.description}
              price={item.data.price}
              gumroadUrl={item.data.gumroadUrl}
              previewImages={item.data.previewImages}
              category={item.data.category}
              featured={item.data.featured}
            />
          ))}
        </div>
      </section>
    )}

    {allItems.length === 0 && (
      <div class="text-center py-20 text-gray-400">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 mx-auto mb-4 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
        </svg>
        <p>商品を準備中です</p>
      </div>
    )}

    <!-- Remotion/動画素材予告 -->
    <div class="mt-8 bg-gradient-to-r from-purple-50 to-karada-blue-light rounded-xl p-6 border border-purple-100">
      <div class="flex items-start gap-4">
        <div class="w-10 h-10 rounded-lg bg-purple-500 flex items-center justify-center flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.069A1 1 0 0121 8.868v6.264a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
          </svg>
        </div>
        <div>
          <h3 class="font-bold text-gray-900 mb-1">近日公開: Remotion動画素材</h3>
          <p class="text-sm text-gray-600">Reactベースの動画制作ライブラリ「Remotion」で制作した医療系アニメーション動画素材を準備中です。SNS・プレゼン・患者説明に使える短尺動画クリップを予定しています。</p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
