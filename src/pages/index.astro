---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const latestPosts = sortedPosts.slice(0, 6);

// "NEW" judgment: published within last 7 days
const now = Date.now();
const SEVEN_DAYS_MS = 7 * 24 * 60 * 60 * 1000;
const isNew = (pubDate: Date) => now - pubDate.valueOf() < SEVEN_DAYS_MS;
---

<BaseLayout title="感染症専門医の医療情報ブログ | 最新エビデンスをわかりやすく解説">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-karada-blue-light via-white to-karada-green-light py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 leading-tight mb-4">医療のギモン、<br class="hidden md:inline" /><span class="text-karada-blue">専門医が読み解きます。</span></h1>
      <p class="text-gray-600 text-lg leading-relaxed mb-8 max-w-2xl mx-auto">
        感染症・ワクチン・抗菌薬・渡航医学などについて、<br />
        感染症専門医が最新の論文やガイドラインをもとに解説します。
      </p>
      <a href="/blog" class="btn-primary justify-center">
        記事一覧
      </a>
    </div>
  </section>

  <!-- Latest Articles -->
  <section class="max-w-5xl mx-auto px-4 py-14">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h2 class="text-2xl font-bold text-gray-900">最新記事</h2>
      </div>
      <a href="/blog" class="text-karada-blue text-sm font-medium hover:underline">
        すべて見る →
      </a>
    </div>

    {latestPosts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {latestPosts.map((post, i) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            ogImage={post.data.ogImage}
            slug={post.slug}
            featured={i === 0}
            isNew={isNew(post.data.pubDate)}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-12 text-gray-400">
        <p>記事を準備中です</p>
      </div>
    )}
  </section>

  <!-- About the author -->
  <section class="bg-gray-50 py-12 px-4">
    <div class="max-w-3xl mx-auto">
      <div class="flex flex-col sm:flex-row items-center sm:items-start gap-6">
        <div class="flex-shrink-0">
          <img src="/images/profile.jpg" alt="Tasunaro" class="w-20 h-20 rounded-full object-cover" />
        </div>
        <div>
          <h2 class="text-xl font-bold text-gray-900 mb-2">書いている人</h2>
          <p class="text-gray-600 leading-relaxed text-sm">
            医師になって10年以上、感染症の診療を続けています。
            医学書や論文の執筆経験を活かして、日々の診療で役立つ情報をお届けします。
          </p>
          <a href="/about" class="inline-block mt-3 text-karada-blue text-sm font-medium hover:underline">
            詳しいプロフィール →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Google AdSense広告エリア (承認後に有効化) -->
</BaseLayout>
