---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const latestPosts = sortedPosts.slice(0, 6);
---

<BaseLayout title="感染症専門医の医療情報ブログ | 最新エビデンスをわかりやすく解説">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-karada-blue-light via-white to-karada-green-light py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 bg-white border border-karada-blue/20 text-karada-blue text-xs font-medium px-3 py-1.5 rounded-full mb-6 shadow-sm">
        <span class="w-1.5 h-1.5 bg-karada-green rounded-full animate-pulse"></span>
        感染症専門医が運営する医療情報ブログ
      </div>
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 leading-tight mb-4">
        感染症専門医が解説する<br class="hidden md:inline" />
        <span class="text-karada-blue">医療・健康情報</span>
      </h1>
      <p class="text-gray-600 text-lg leading-relaxed mb-8 max-w-2xl mx-auto">
        ワクチン・感染症・抗菌薬・渡航医学について、最新のエビデンスをもとに
        わかりやすく解説しています。
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/blog" class="btn-primary justify-center">
          記事を読む
        </a>
        <a href="/about" class="btn-secondary justify-center">
          書いている人
        </a>
      </div>
    </div>
  </section>

  <!-- Latest Articles -->
  <section class="max-w-5xl mx-auto px-4 py-14">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h2 class="text-2xl font-bold text-gray-900">最新記事</h2>
        <p class="text-sm text-gray-500 mt-1">エビデンスに基づいた医療情報</p>
      </div>
      <a href="/blog" class="text-karada-blue text-sm font-medium hover:underline">
        すべて見る →
      </a>
    </div>

    {latestPosts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {latestPosts.map((post, i) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            slug={post.slug}
            featured={i === 0}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-12 text-gray-400">
        <p>記事を準備中です</p>
      </div>
    )}
  </section>

  <!-- About the author -->
  <section class="bg-gray-50 py-12 px-4">
    <div class="max-w-3xl mx-auto">
      <div class="flex flex-col sm:flex-row items-center sm:items-start gap-6">
        <div class="flex-shrink-0">
          <div class="w-20 h-20 rounded-full bg-karada-blue flex items-center justify-center text-white text-2xl font-bold">
            T
          </div>
        </div>
        <div>
          <h2 class="text-xl font-bold text-gray-900 mb-2">書いている人</h2>
          <p class="text-gray-600 leading-relaxed text-sm">
            医師になって10年以上、感染症の診療を続けています。
            医学書や論文の執筆経験を活かして、日々の診療で役立つ情報をお届けします。
          </p>
          <a href="/about" class="inline-block mt-3 text-karada-blue text-sm font-medium hover:underline">
            詳しいプロフィール →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Google AdSense広告エリア (承認後に有効化) -->
</BaseLayout>
