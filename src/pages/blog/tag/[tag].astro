---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);
  const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags))];

  return allTags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: allPosts
        .filter((post) => post.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
const allPosts = await getCollection('blog', ({ data }) => !data.draft);

// Popular tags: 2+ articles, OR the current tag (always include for navigation)
const tagCount = allPosts.flatMap(p => p.data.tags).reduce<Record<string, number>>((acc, t) => {
  acc[t] = (acc[t] || 0) + 1;
  return acc;
}, {});
const popularTags = Object.entries(tagCount)
  .filter(([t, count]) => count >= 2 || t === tag)
  .sort((a, b) => b[1] - a[1]);
---

<BaseLayout
  title={`#${tag} の記事一覧 | Tasunaro`}
  description={`「${tag}」に関する記事一覧です。感染症専門医が最新のエビデンスに基づいて解説します。`}
>
  <div class="max-w-5xl mx-auto px-4 py-10">
    <div class="mb-8">
      <nav class="text-sm text-gray-500 mb-4">
        <a href="/" class="hover:text-karada-blue">ホーム</a>
        <span class="mx-2">/</span>
        <a href="/blog" class="hover:text-karada-blue">記事一覧</a>
        <span class="mx-2">/</span>
        <span class="text-gray-700">#{tag}</span>
      </nav>
      <h1 class="text-3xl font-bold text-gray-900 mb-2">#{tag}</h1>
      <p class="text-gray-500">{posts.length}件の記事</p>
    </div>

    <!-- Tag filter (popular tags only, with article counts) -->
    <div class="mb-8 pb-6 border-b border-gray-100">
      <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-3" style="letter-spacing: 0.18em;">よく読まれているテーマ</p>
      <div class="flex flex-wrap gap-2">
        <a href="/blog" class="tag-badge hover:bg-karada-blue hover:text-white transition-colors">すべて ({allPosts.length})</a>
        {popularTags.map(([t, count]) => (
          <a
            href={`/blog/tag/${t}`}
            class:list={[
              'tag-badge transition-colors',
              t === tag ? 'bg-karada-blue text-white' : 'hover:bg-karada-blue hover:text-white',
            ]}
          >
            #{t} <span class="opacity-60">({count})</span>
          </a>
        ))}
      </div>
    </div>

    <!-- Articles grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {posts.map((post) => (
        <ArticleCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          tags={post.data.tags}
          ogImage={post.data.ogImage}
          slug={post.slug}
        />
      ))}
    </div>
  </div>
</BaseLayout>
