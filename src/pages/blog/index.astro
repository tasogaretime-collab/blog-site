---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Tag with article count, filter to tags with 2+ articles, sort by count desc
const tagCount = allPosts.flatMap(p => p.data.tags).reduce<Record<string, number>>((acc, tag) => {
  acc[tag] = (acc[tag] || 0) + 1;
  return acc;
}, {});
const popularTags = Object.entries(tagCount)
  .filter(([, count]) => count >= 2)
  .sort((a, b) => b[1] - a[1]);

// Determine "NEW" articles (published within last 7 days)
const now = Date.now();
const SEVEN_DAYS_MS = 7 * 24 * 60 * 60 * 1000;
const isNew = (pubDate: Date) => now - pubDate.valueOf() < SEVEN_DAYS_MS;

// Featured = latest article
const featuredPost = sortedPosts[0];
const otherPosts = sortedPosts.slice(1);
---

<BaseLayout
  title="記事一覧 | 感染症専門医の医療情報ブログ"
  description="感染症・ワクチン・抗菌薬・渡航医学について、最新のエビデンスに基づいて解説する記事一覧です。"
>
  <div class="max-w-5xl mx-auto px-4 py-10">
    <div class="mb-8 flex items-end justify-between flex-wrap gap-3">
      <div>
        <h1 class="text-3xl font-bold text-gray-900 mb-2">記事一覧</h1>
        <p class="text-gray-500">感染症・ワクチン・抗菌薬・渡航医学について、最新のエビデンスに基づいて解説します。</p>
      </div>
      <div class="text-sm text-gray-500">
        <span class="font-bold text-karada-blue text-lg">{sortedPosts.length}</span> 本の記事
      </div>
    </div>

    <!-- Tag filter (popular tags only, with article counts) -->
    {popularTags.length > 0 && (
      <div class="mb-8 pb-6 border-b border-gray-100">
        <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-3" style="letter-spacing: 0.18em;">よく読まれているテーマ</p>
        <div class="flex flex-wrap gap-2">
          <a href="/blog" class="tag-badge bg-karada-blue text-white">すべて ({sortedPosts.length})</a>
          {popularTags.map(([tag, count]) => (
            <a href={`/blog/tag/${tag}`} class="tag-badge hover:bg-karada-blue hover:text-white transition-colors">
              #{tag} <span class="opacity-60">({count})</span>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Featured (latest) article -->
    {featuredPost && (
      <div class="mb-8">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-[11px] font-bold uppercase tracking-widest text-karada-blue" style="letter-spacing: 0.18em;">最新の記事</span>
        </div>
        <ArticleCard
          title={featuredPost.data.title}
          description={featuredPost.data.description}
          pubDate={featuredPost.data.pubDate}
          tags={featuredPost.data.tags}
          ogImage={featuredPost.data.ogImage}
          slug={featuredPost.slug}
          featured={true}
          isNew={isNew(featuredPost.data.pubDate)}
        />
      </div>
    )}

    <!-- Other articles grid -->
    {otherPosts.length > 0 ? (
      <>
        <h2 class="text-sm font-bold uppercase tracking-widest text-gray-400 mb-4" style="letter-spacing: 0.18em;">これまでの記事</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {otherPosts.map((post) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
              ogImage={post.data.ogImage}
              slug={post.slug}
              isNew={isNew(post.data.pubDate)}
            />
          ))}
        </div>
      </>
    ) : sortedPosts.length === 0 && (
      <div class="text-center py-20 text-gray-400">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 mx-auto mb-4 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        <p>記事を準備中です</p>
      </div>
    )}
  </div>
</BaseLayout>
