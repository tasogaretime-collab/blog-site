---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Collect all tags
const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags))].sort();
---

<BaseLayout
  title="記事一覧 | 感染症専門医の医療情報ブログ"
  description="感染症・ワクチン・抗菌薬・渡航医学について、最新のエビデンスに基づいて解説する記事一覧です。"
>
  <div class="max-w-5xl mx-auto px-4 py-10">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 mb-2">記事一覧</h1>
      <p class="text-gray-500">感染症・ワクチン・抗菌薬・渡航医学について、{allPosts.length}本の記事</p>
    </div>

    <!-- Tag filter -->
    {allTags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-8 pb-6 border-b border-gray-100">
        <a href="/blog" class="tag-badge bg-karada-blue text-white">すべて</a>
        {allTags.map((tag) => (
          <a href={`/blog/tag/${tag}`} class="tag-badge hover:bg-karada-blue hover:text-white transition-colors">
            #{tag}
          </a>
        ))}
      </div>
    )}

    <!-- Articles grid -->
    {sortedPosts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {sortedPosts.map((post) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            slug={post.slug}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-20 text-gray-400">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 mx-auto mb-4 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        <p>記事を準備中です</p>
      </div>
    )}
  </div>
</BaseLayout>
