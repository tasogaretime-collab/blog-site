---
interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;
---

{compact ? (
  <div class="flex items-center gap-3 p-4 bg-gray-50 rounded-lg border border-gray-100">
    <img src="/images/profile.jpg" alt="Tasunaro" class="w-12 h-12 rounded-full object-cover flex-shrink-0" />
    <div>
      <div class="font-bold text-gray-900 text-sm">Tasunaro</div>
      <div class="text-xs text-gray-500">感染症専門医</div>
    </div>
  </div>
) : (
  <div class="bg-karada-blue-light rounded-xl p-6 border border-karada-blue/20">
    <div class="flex items-start gap-4">
      <img src="/images/profile.jpg" alt="Tasunaro" class="w-16 h-16 rounded-full object-cover flex-shrink-0" />
      <div class="flex-1 min-w-0">
        <div class="font-bold text-gray-900 text-lg mb-0.5">Tasunaro</div>
        <div class="text-sm text-karada-blue font-medium mb-3">感染症専門医</div>
        <div class="flex flex-wrap gap-1.5 mb-3">
          <span class="inline-flex items-center px-2 py-0.5 text-[11px] font-medium text-karada-blue bg-white border border-karada-blue/30 rounded-full">日本感染症学会専門医</span>
          <span class="inline-flex items-center px-2 py-0.5 text-[11px] font-medium text-karada-blue bg-white border border-karada-blue/30 rounded-full">抗菌化学療法指導医</span>
          <span class="inline-flex items-center px-2 py-0.5 text-[11px] font-medium text-karada-blue bg-white border border-karada-blue/30 rounded-full">国際渡航医学会認定医</span>
          <span class="inline-flex items-center px-2 py-0.5 text-[11px] font-medium text-karada-blue bg-white border border-karada-blue/30 rounded-full">DTM&amp;H</span>
        </div>
        <p class="text-sm text-gray-600 leading-relaxed">
          医師になって10年以上、感染症の診療を続けています。
          査読論文や医学書の執筆経験を活かし、最新のエビデンスに基づいた情報をお届けします。
        </p>
        <div class="flex items-center gap-4 mt-3">
          <a
            href="/about"
            class="text-xs text-karada-blue font-bold hover:underline transition-colors"
          >
            詳しいプロフィール →
          </a>
          <a
            href="https://x.com/xRLtqMcxxZ75089"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-xs text-gray-500 hover:text-black transition-colors"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
            @Tasunaro
          </a>
        </div>
      </div>
    </div>
  </div>
)}
