---
interface Props {
  title: string;
  description: string;
  price: number;
  currency?: string;
  gumroadUrl?: string;
  previewImages?: string[];
  category: 'svg-icons' | 'pptx-template' | 'guide';
  featured?: boolean;
}

const {
  title,
  description,
  price,
  currency = 'JPY',
  gumroadUrl,
  previewImages = [],
  category,
  featured = false,
} = Astro.props;

const categoryLabel = {
  'svg-icons': '医療アイコン',
  'pptx-template': 'PPTXテンプレート',
  'guide': '解説資料',
}[category];

const categoryColor = {
  'svg-icons': 'bg-purple-100 text-purple-700',
  'pptx-template': 'bg-karada-blue-light text-karada-blue',
  'guide': 'bg-karada-green-light text-karada-green',
}[category];

const formattedPrice = new Intl.NumberFormat('ja-JP', {
  style: 'currency',
  currency,
}).format(price);
---

<div class={`card p-5 border ${featured ? 'border-karada-blue' : 'border-gray-200'} relative`}>
  {featured && (
    <div class="absolute -top-2.5 left-4 bg-karada-blue text-white text-xs font-bold px-3 py-1 rounded-full">
      おすすめ
    </div>
  )}

  <div class="flex gap-4">
    <!-- Preview -->
    {previewImages.length > 0 ? (
      <div class="flex-shrink-0">
        <img
          src={previewImages[0]}
          alt={title}
          class="w-24 h-24 object-cover rounded-lg border border-gray-100"
          loading="lazy"
        />
      </div>
    ) : (
      <div class="flex-shrink-0 w-24 h-24 bg-karada-blue-light rounded-lg flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-karada-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
    )}

    <!-- Info -->
    <div class="flex-1 min-w-0">
      <div class="flex items-start justify-between gap-2 mb-1.5">
        <div>
          <span class={`inline-block text-xs font-medium px-2 py-0.5 rounded-full mb-1 ${categoryColor}`}>
            {categoryLabel}
          </span>
          <h4 class="font-bold text-gray-900 text-sm leading-snug">{title}</h4>
        </div>
        <div class="text-right flex-shrink-0">
          <div class="text-lg font-bold text-karada-blue">{formattedPrice}</div>
          {price === 0 && <div class="text-xs text-karada-green font-medium">無料</div>}
        </div>
      </div>
      <p class="text-xs text-gray-500 leading-relaxed mb-3 line-clamp-2">{description}</p>

      {gumroadUrl ? (
        <a
          href={gumroadUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary text-sm py-2 px-4"
          data-gumroad-single-product="true"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
          {price === 0 ? '無料ダウンロード' : '購入する (Gumroad)'}
        </a>
      ) : (
        <span class="inline-block text-xs text-gray-400 bg-gray-100 px-3 py-1.5 rounded-lg">
          準備中
        </span>
      )}
    </div>
  </div>
</div>

<!-- Gumroad JS (loaded once per page) -->
<script is:inline>
  if (!window.__gumroadLoaded) {
    window.__gumroadLoaded = true;
    const s = document.createElement('script');
    s.src = 'https://gumroad.com/js/gumroad.js';
    s.async = true;
    document.head.appendChild(s);
  }
</script>
