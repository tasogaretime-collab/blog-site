---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
}

const { title, description = '感染症専門医が最新のエビデンスに基づいて医療・健康情報をわかりやすく解説します。', ogImage, ogType = 'website' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const defaultOgImage = new URL('/images/og-default.png', Astro.site).href;
const resolvedOgImage = ogImage ? new URL(ogImage, Astro.site).href : defaultOgImage;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- OGP -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:site_name" content="Tasunaro ─ 感染症専門医の医療情報ブログ" />
    <meta property="og:locale" content="ja_JP" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:site" content="@Tasunaro" />
    <meta name="twitter:image" content={resolvedOgImage} />

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Tasunaro ─ 感染症専門医の医療情報ブログ",
      "url": Astro.site?.href,
      "author": {
        "@type": "Person",
        "name": "Tasunaro",
        "jobTitle": "感染症専門医",
        "url": new URL("/about", Astro.site).href,
      },
    })} />

    <!-- Google AdSense -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7787421522863807" crossorigin="anonymous"></script>

    <slot name="head" />

    <!-- Google Analytics (GA4) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-NDBGCC9WCV"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-NDBGCC9WCV');
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Header -->
    <header class="sticky top-0 z-50 bg-white border-b border-gray-100 shadow-sm">
      <div class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 group">
          <img src="/images/profile.jpg" alt="Tasunaro" class="w-8 h-8 rounded-full object-cover" />
          <div>
            <div class="font-bold text-gray-900 group-hover:text-karada-blue transition-colors text-sm leading-tight">Tasunaro</div>
            <div class="hidden sm:block text-xs text-gray-500">感染症専門医の医療情報ブログ</div>
          </div>
        </a>
        <nav class="flex items-center gap-1">
          <a href="/blog" class="px-3 py-1.5 text-sm text-gray-700 hover:text-karada-blue hover:bg-karada-blue-light rounded-lg transition-colors">記事</a>
          <a href="/about" class="px-3 py-1.5 text-sm text-gray-700 hover:text-karada-blue hover:bg-karada-blue-light rounded-lg transition-colors">プロフィール</a>
        </nav>
      </div>
    </header>

    <!-- Main content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-gray-900 text-gray-300 mt-16">
      <div class="max-w-5xl mx-auto px-4 py-10">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
          <div>
            <div class="text-white font-bold mb-3">Tasunaro</div>
            <p class="text-sm text-gray-400 leading-relaxed">感染症専門医が、最新のエビデンスをもとに医療・健康情報をわかりやすくお届けします。</p>
          </div>
          <div>
            <div class="text-white font-bold mb-3">コンテンツ</div>
            <ul class="space-y-1 text-sm">
              <li><a href="/blog" class="hover:text-karada-blue transition-colors">医療記事</a></li>
              <li><a href="/about" class="hover:text-karada-blue transition-colors">プロフィール</a></li>
            </ul>
          </div>
          <div>
            <div class="text-white font-bold mb-3">このサイトについて</div>
            <p class="text-sm text-gray-400 mt-1">
              <a href="/privacy" class="hover:text-gray-200">プライバシーポリシー</a> /
              <a href="/disclaimer" class="hover:text-gray-200"> 免責事項</a>
            </p>
          </div>
        </div>
        <div class="border-t border-gray-700 pt-6 flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-gray-500">
          <p>© {new Date().getFullYear()} Tasunaro. All rights reserved.</p>
          <div class="flex gap-4">
            <a href="/privacy" class="hover:text-gray-300">プライバシーポリシー</a>
            <a href="/disclaimer" class="hover:text-gray-300">免責事項</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
