---
import BaseLayout from './BaseLayout.astro';
import SlideViewer from '../components/SlideViewer.astro';
import AuthorProfile from '../components/AuthorProfile.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface FaqItem {
  q: string;
  a: string;
}

interface NavPost {
  slug: string;
  title: string;
}

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  slides?: string[];
  ogImage?: string;
  headings?: Heading[];
  faq?: FaqItem[];
  prevPost?: NavPost;
  nextPost?: NavPost;
}

const { title, description, pubDate, updatedDate, tags = [], slides, ogImage, headings = [], faq, prevPost, nextPost } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Filter h2 headings for TOC
const tocHeadings = headings.filter(h => h.depth === 2);

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "ホーム", "item": Astro.site?.href },
    { "@type": "ListItem", "position": 2, "name": "記事一覧", "item": new URL("/blog", Astro.site).href },
    { "@type": "ListItem", "position": 3, "name": title },
  ],
};

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  "headline": title,
  "description": description,
  "datePublished": pubDate.toISOString(),
  ...(updatedDate && { "dateModified": updatedDate.toISOString() }),
  "author": {
    "@type": "Person",
    "name": "Tasunaro",
    "jobTitle": "感染症専門医",
    "url": new URL("/about", Astro.site).href,
  },
  "publisher": {
    "@type": "Person",
    "name": "Tasunaro",
  },
  "mainEntityOfPage": canonicalURL.href,
  ...(tags.length > 0 && { "keywords": tags.join(", ") }),
};

const stripTags = (s: string) => s.replace(/<[^>]*>/g, '');

const faqJsonLd = faq && faq.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map(item => ({
    "@type": "Question",
    "name": stripTags(item.q),
    "acceptedAnswer": {
      "@type": "Answer",
      "text": stripTags(item.a),
    },
  })),
} : null;

// Format dates
const formattedPubDate = pubDate.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const formattedUpdatedDate = updatedDate?.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} | Tasunaro`} description={description} ogImage={ogImage} ogType="article">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
    {faqJsonLd && <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@400;700&display=swap" rel="stylesheet" />
  </Fragment>

  <article>
    <!-- Article Header -->
    <div class="max-w-3xl mx-auto px-4 pt-10 pb-8">
      <!-- Breadcrumb (minimal) -->
      <nav class="text-xs text-gray-400 mb-8">
        <a href="/" class="hover:text-gray-600 transition-colors">ホーム</a>
        <span class="mx-1.5">/</span>
        <a href="/blog" class="hover:text-gray-600 transition-colors">記事一覧</a>
      </nav>

      <!-- Title -->
      <h1 class="article-title text-3xl md:text-4xl font-bold text-gray-900 leading-tight mb-6" style="font-family: 'Noto Serif JP', serif;">
        {title}
      </h1>

      <!-- Meta line -->
      <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-gray-500 mb-6">
        <div class="flex items-center gap-2">
          <img src="/images/profile.jpg" alt="Tasunaro" class="w-6 h-6 rounded-full object-cover" />
          <a href="/about" class="font-medium text-gray-700 hover:text-karada-blue transition-colors">Tasunaro</a>
          <span class="text-gray-300">·</span>
          <span class="text-gray-400">感染症専門医</span>
        </div>
        <div class="flex items-center gap-3 text-xs text-gray-400">
          <time datetime={pubDate.toISOString()}>
            {formattedPubDate}
          </time>
          {updatedDate && (
            <span>
              更新 {formattedUpdatedDate}
            </span>
          )}
        </div>
      </div>

      <!-- Tags -->
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5">
          {tags.map((tag) => (
            <a
              href={`/blog/tag/${tag}`}
              class="text-xs text-gray-400 hover:text-karada-blue transition-colors"
            >
              #{tag}
            </a>
          ))}
        </div>
      )}

      <!-- Hero image -->
      {ogImage && (
        <div class="mt-8">
          <img src={ogImage} alt={title} class="w-full rounded-xl object-cover" />
        </div>
      )}
    </div>

    <!-- Thin divider -->
    <div class="max-w-3xl mx-auto px-4">
      <div class="border-t border-gray-100"></div>
    </div>

    <!-- Main content area -->
    <div class="max-w-5xl mx-auto px-4 py-8">
      <div class="lg:flex lg:gap-12">

        <!-- Article body -->
        <div class="flex-1 min-w-0 max-w-3xl">
          <!-- Slide Viewer (if slides exist) -->
          {slides && slides.length > 0 && (
            <div class="mb-8">
              <SlideViewer slides={slides} title={title} />
            </div>
          )}

          <!-- Article content -->
          <div class="prose prose-lg max-w-none">
            <slot />
          </div>

          <!-- FAQ Section -->
          {faq && faq.length > 0 && (
            <section class="mt-16 pt-8 border-t border-gray-100">
              <h2 class="text-2xl font-bold text-gray-900 mb-8" style="font-family: 'Noto Serif JP', serif;">よくある質問</h2>
              <div class="space-y-6">
                {faq.map((item) => (
                  <details class="group border border-gray-100 rounded-lg">
                    <summary class="flex items-center justify-between cursor-pointer px-5 py-4 text-base font-medium text-gray-800 hover:bg-gray-50 transition-colors rounded-lg">
                      <span set:html={item.q} />
                      <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                    </summary>
                    <div class="px-5 pb-4 text-sm text-gray-600 leading-relaxed" set:html={item.a} />
                  </details>
                ))}
              </div>
            </section>
          )}

          <!-- Prev/Next post navigation -->
          {(prevPost || nextPost) && (
            <nav class="mt-16 pt-8 border-t border-gray-100" aria-label="記事ナビゲーション">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                {prevPost ? (
                  <a
                    href={`/blog/${prevPost.slug}`}
                    class="group flex flex-col gap-2 rounded-lg border border-gray-100 px-5 py-4 transition-all hover:border-karada-blue hover:shadow-sm"
                  >
                    <span class="flex items-center gap-1.5 text-[11px] font-semibold uppercase tracking-widest text-gray-400 group-hover:text-karada-blue transition-colors" style="letter-spacing: 0.18em;">
                      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" /></svg>
                      前の記事
                    </span>
                    <span class="text-sm font-medium text-gray-800 group-hover:text-karada-blue transition-colors leading-snug line-clamp-2">
                      {prevPost.title}
                    </span>
                  </a>
                ) : (
                  <div class="hidden md:block"></div>
                )}

                {nextPost ? (
                  <a
                    href={`/blog/${nextPost.slug}`}
                    class="group flex flex-col gap-2 rounded-lg border border-gray-100 px-5 py-4 transition-all hover:border-karada-blue hover:shadow-sm md:text-right"
                  >
                    <span class="flex items-center gap-1.5 text-[11px] font-semibold uppercase tracking-widest text-gray-400 group-hover:text-karada-blue transition-colors md:justify-end" style="letter-spacing: 0.18em;">
                      次の記事
                      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" /></svg>
                    </span>
                    <span class="text-sm font-medium text-gray-800 group-hover:text-karada-blue transition-colors leading-snug line-clamp-2">
                      {nextPost.title}
                    </span>
                  </a>
                ) : (
                  <div class="hidden md:block"></div>
                )}
              </div>
            </nav>
          )}

          <!-- Article footer -->
          <footer class="mt-16 pt-8 border-t border-gray-100">
            <!-- Author -->
            <AuthorProfile />

            <!-- Share + Disclaimer -->
            <div class="mt-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
              <a
                href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(Astro.url.href)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 text-sm text-gray-400 hover:text-gray-700 transition-colors"
              >
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
                シェアする
              </a>
              <p class="text-xs text-gray-300 m-0">
                本記事は医療情報の提供を目的としており、診断・治療の代替となるものではありません。
              </p>
            </div>
          </footer>
        </div>

        <!-- Sidebar TOC (desktop only) -->
        {tocHeadings.length > 2 && (
          <aside class="hidden lg:block w-56 shrink-0">
            <nav class="sticky top-24 pt-2">
              <p class="text-[10px] font-semibold uppercase tracking-widest mb-5" style="letter-spacing: 0.18em; color: #c8c8c8;">
                Contents
              </p>
              <ul class="space-y-1 list-none m-0 p-0 border-l border-gray-100">
                {tocHeadings.map((heading) => (
                  <li class="m-0 p-0">
                    <a href={`#${heading.slug}`} class="toc-link">
                      {heading.text}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </aside>
        )}
      </div>
    </div>
  </article>
</BaseLayout>
